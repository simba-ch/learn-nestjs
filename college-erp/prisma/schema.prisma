// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String  @unique
  password        String
  username        String  @unique
  dob             String?
  joiningYear     String?
  avatar          String?
  contactNumber   String?
  passwordUpdated Boolean @default(false)
  department      String?
}

model Attendance {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  totalLecturesByFaculty Int       @default(0)
  lectureAttended        Int       @default(0)
  student                Student[]
  subject                Subject[]
}

model Department {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  department     String
  departmentCode String @unique
}

model Index {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  departmentLatest String @default("00")
}

model Faculty {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String  @unique
  avatar          String?
  password        String?
  username        String?
  gender          String?
  designation     String
  contactNumber   String?
  dob             String
  joiningYear     Int
  passwordUpdated Boolean @default(false)
  department      String
}

model Marks {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  marks   Int       @default(-1)
  exam    Test[]
  student Student[]
}

model Notice {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  topic     String
  date      String
  content   String
  from      String
  noticeFor String
}

model Student {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  email               String             @unique
  avatar              String?
  password            String
  year                String
  username            String?
  gender              String?
  fatherName          String?
  motherName          String?
  section             String
  batch               String?
  contactNumber       String?
  fatherContactNumber String?
  motherContactNumber String?
  dob                 String
  passwordUpdated     Boolean            @default(false)
  department          String
  subjects            StudentOfSubject[]
  Attendance          Attendance?        @relation(fields: [attendanceId], references: [id])
  attendanceId        String?            @db.ObjectId
  Marks               Marks?             @relation(fields: [marksId], references: [id])
  marksId             String?            @db.ObjectId
}

model Subject {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  subjectName   String
  subjectCode   String
  totalLectures Int                @default(10)
  year          String
  department    String
  Attendance    Attendance?        @relation(fields: [attendanceId], references: [id])
  attendanceId  String?            @db.ObjectId
  students      StudentOfSubject[]
}

model StudentOfSubject {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?  @db.ObjectId
  subject   Subject? @relation(fields: [subjectId], references: [id])
  subjectId String?  @db.ObjectId
}

model Test {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  test        String
  subjectCode String
  totalMarks  Int     @default(10)
  year        String
  section     String
  date        String
  department  String
  Marks       Marks?  @relation(fields: [marksId], references: [id])
  marksId     String? @db.ObjectId
}
